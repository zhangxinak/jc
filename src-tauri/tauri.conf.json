{
  "$schema": "https://schema.tauri.app/config/1.0",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "机器码获取工具",
    "version": "2.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "window": { "all": true },
      "fs": { "all": false },
      "http": { "all": false },
      "dialog": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.glodon.machine-code-tool",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/256x256.png",
        "icons/512x512.png",
        "icons/icon.png",
        "icons/icon.ico",
        "icons/icon.icns"
      ],
      "macOS": {
        "minimumSystemVersion": "10.13"
      },
      "shortDescription": "机器码获取工具",
      "longDescription": "跨平台硬件信息获取与投标API服务",
      "category": "Utility"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "机器码获取工具",
        "width": 790,
        "height": 490,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ]
  },
  "plugins": {}
}
